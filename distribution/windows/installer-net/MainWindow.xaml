<ui:FluentWindow x:Class="Readarr.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Readarr Installer"
        Width="780"
        Height="560"
        MinWidth="640"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="Readarr Installer"
                     Icon="pack://application:,,,/Resources/Readarr.ico" />

        <!-- App identity + step/progress panel -->
        <StackPanel Grid.Row="1" Margin="24,16,24,8">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Image Source="pack://application:,,,/Resources/Readarr.png"
                       Width="48" Height="48"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center" />
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                    <ui:TextBlock Text="Readarr"
                                  FontTypography="Title"
                                  FontWeight="SemiBold" />
                    <ui:TextBlock Text="Book Manager for Usenet and BitTorrent"
                                  FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
            <ui:TextBlock x:Name="StepLabel"
                          FontTypography="Subtitle"
                          Text="Ready to install." />
            <ui:TextBlock x:Name="DetailLabel"
                          FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          Margin="0,2,0,12" />
            <ProgressBar x:Name="Progress"
                         Height="6"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         IsIndeterminate="False" />
        </StackPanel>

        <!-- Log panel -->
        <Border Grid.Row="2"
                Margin="24,12,24,12"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                CornerRadius="4">
            <ScrollViewer x:Name="LogScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          ScrollChanged="LogScroller_ScrollChanged"
                          Padding="12,8,12,8">
                <TextBlock x:Name="LogText"
                           FontFamily="Consolas, Cascadia Mono, Courier New"
                           FontSize="12"
                           TextWrapping="NoWrap"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="24,0,24,20">
            <ui:Button x:Name="RestoreButton"
                       Content="Restore previous"
                       Appearance="Secondary"
                       Visibility="Collapsed"
                       Margin="0,0,8,0"
                       Click="RestoreButton_Click" />
            <ui:Button x:Name="InstallButton"
                       Content="Install"
                       Appearance="Primary"
                       Margin="0,0,8,0"
                       Click="InstallButton_Click" />
            <ui:Button x:Name="CancelButton"
                       Content="Cancel"
                       Appearance="Secondary"
                       IsEnabled="False"
                       Margin="0,0,8,0"
                       Click="CancelButton_Click" />
            <ui:Button x:Name="CloseButton"
                       Content="Close"
                       Appearance="Secondary"
                       Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
